# Окружение
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# База данных PostgreSQL
DATABASE_URL=postgresql://privox:password@localhost:5432/privoxptt

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=CHANGE_ME_super_secret_key_minimum_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=CHANGE_ME_refresh_secret_key_minimum_32_chars
REFRESH_TOKEN_EXPIRES_IN=30d

# MediaSoup WebRTC
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=YOUR_SERVER_IP_HERE
MEDIASOUP_MIN_PORT=10000
MEDIASOUP_MAX_PORT=10100
MEDIASOUP_NUM_WORKERS=1

# CORS — разрешённые origins (через запятую)
CORS_ORIGINS=http://localhost:5173,https://ptt.privox.tech

# Push уведомления (Этап 3)
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=

# Первый суперадмин (используется при seed)
SUPERADMIN_EMAIL=admin@privox.tech
SUPERADMIN_PASSWORD=CHANGE_ME_strong_password
SUPERADMIN_CALLSIGN=ALPHA-0
